<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OTUS Wishlist Automation Suite" verbose="2" parallel="tests" thread-count="2">

    <parameter name="browser" value="chrome"/>
    <parameter name="environment" value="staging"/>
    <parameter name="timeout" value="60000"/>

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Authorization Tests">
        <classes>
            <class name="tests.ui.LoginUITest"/>
            <class name="tests.api.AuthApiTest"/>
        </classes>
    </test>

    <test name="Registration Tests">
        <classes>
            <class name="tests.ui.RegistrationUITest"/>
        </classes>
    </test>

    <test name="Wishlist Management Tests">
        <classes>
            <class name="tests.ui.WishlistUITest"/>
        </classes>
    </test>

</suite>
